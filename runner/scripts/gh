#!/bin/sh
# Chetter gh wrapper — blocks GitHub write commands so agents must use Chetter
# MCP tools instead. This ensures every issue, comment, PR, and review gets a
# canonical signature, audit log entry, and artifact record.
#
# Blocked: aliases, gh api <any>, GitHub writes, and unknown commands.
# Allowed: known read-only commands (issue view/list, pr view/checks, search, etc.)
#
# Real binary: /usr/local/bin/gh-real
set -eu

GH_REAL="${CHETTER_GH_REAL:-/usr/local/bin/gh-real}"

GH_SAFE_CONFIG_DIR=$(mktemp -d "${TMPDIR:-/tmp}/chetter-gh.XXXXXX")
trap 'rm -rf "$GH_SAFE_CONFIG_DIR"' EXIT HUP INT TERM

_blocked() {
  cat >&2 <<'EOF'
Chetter-managed GitHub writes must go through MCP tools so every artifact
gets a canonical signature, audit log entry, and artifact record:

  chetter_create_issue    — instead of gh issue create or gh api
  chetter_issue_comment   — instead of gh issue comment, gh pr comment, or gh api
  chetter_create_pr       — instead of gh pr create or gh api
  chetter_pr_review       — instead of gh pr review or gh api

Read-only gh commands are still available (issue view/list, pr view/checks, etc.).
Use the Chetter MCP tools listed above. These ensure proper audit logging and
canonical Chetter signatures on every artifact.
EOF
  exit 64
}

cmd1=""
cmd2=""
skip_next=0
for arg in "$@"; do
  if [ "$skip_next" = "1" ]; then
    skip_next=0
    continue
  fi
  case "$arg" in
    --)
      break
      ;;
    --repo|--hostname|--config-dir|--git-protocol|--editor|-R)
      skip_next=1
      continue
      ;;
    --repo=*|--hostname=*|--config-dir=*|--git-protocol=*|--editor=*|-R*)
      continue
      ;;
    -*)
      continue
      ;;
  esac
  if [ -z "$cmd1" ]; then
    cmd1="$arg"
    continue
  fi
  if [ -z "$cmd2" ]; then
    cmd2="$arg"
    break
  fi
done

case "$cmd1" in
  alias|api|auth|gpg-key|ssh-key|secret|variable)
    _blocked
    ;;
  issue)
    case "$cmd2" in
      create|comment|close|delete|edit|lock|pin|reopen|transfer|unlock|unpin) _blocked ;;
      develop|list|status|view) ;;
      *) _blocked ;;
    esac
    ;;
  pr)
    case "$cmd2" in
      close|comment|create|edit|lock|merge|ready|reopen|review|unlock) _blocked ;;
      checkout|checks|diff|list|status|view) ;;
      *) _blocked ;;
    esac
    ;;
  release)
    case "$cmd2" in
      create|delete|delete-asset|edit|upload) _blocked ;;
      download|list|view) ;;
      *) _blocked ;;
    esac
    ;;
  repo)
    case "$cmd2" in
      archive|create|delete|deploy-key|edit|fork|rename|sync|unarchive) _blocked ;;
      clone|list|view) ;;
      *) _blocked ;;
    esac
    ;;
  gist)
    case "$cmd2" in
      create|delete|edit) _blocked ;;
      clone|list|view) ;;
      *) _blocked ;;
    esac
    ;;
  label)
    case "$cmd2" in
      create|delete|edit) _blocked ;;
      list) ;;
      *) _blocked ;;
    esac
    ;;
  milestone)
    case "$cmd2" in
      close|create|delete|edit|reopen) _blocked ;;
      list|view) ;;
      *) _blocked ;;
    esac
    ;;
  project)
    case "$cmd2" in
      archive|close|create|delete|edit|item-add|item-archive|item-create|item-delete|item-edit|link|unlink) _blocked ;;
      field-list|item-list|list|view) ;;
      *) _blocked ;;
    esac
    ;;
  workflow)
    case "$cmd2" in
      disable|enable|run) _blocked ;;
      list|view) ;;
      *) _blocked ;;
    esac
    ;;
  run)
    case "$cmd2" in
      cancel|delete|rerun) _blocked ;;
      download|list|view|watch) ;;
      *) _blocked ;;
    esac
    ;;
  cache)
    case "$cmd2" in
      delete) _blocked ;;
      list) ;;
      *) _blocked ;;
    esac
    ;;
  codespace)
    case "$cmd2" in
      create|delete|edit|ports|rebuild|stop) _blocked ;;
      code|cp|jupyter|list|logs|ssh|view) ;;
      *) _blocked ;;
    esac
    ;;
  config)
    case "$cmd2" in
      get|list) ;;
      *) _blocked ;;
    esac
    ;;
  extension)
    case "$cmd2" in
      list) ;;
      *) _blocked ;;
    esac
    ;;
  browse|completion|help|ruleset|search|status)
    ;;
  *)
    _blocked
    ;;
esac

GH_CONFIG_DIR="$GH_SAFE_CONFIG_DIR" "$GH_REAL" "$@"
