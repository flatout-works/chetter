#!/bin/sh
# Chetter gh wrapper — blocks GitHub write commands so agents must use Chetter
# MCP tools instead. This ensures every issue, comment, PR, and review gets a
# canonical signature, audit log entry, and artifact record.
#
# Blocked: gh api <any>, gh issue create/comment, gh pr create/review/comment
# Allowed: all read-only commands (issue view/list, pr view/checks, search, etc.)
# Bypass:  set CHETTER_ALLOW_GH_WRITES=1 for manual debugging only.
#
# Real binary: /usr/local/bin/gh-real
set -eu

if [ "${CHETTER_ALLOW_GH_WRITES:-}" = "1" ]; then
  exec /usr/local/bin/gh-real "$@"
fi

_blocked() {
  cat >&2 <<'EOF'
Chetter-managed GitHub writes must go through MCP tools so every artifact
gets a canonical signature, audit log entry, and artifact record:

  chetter_create_issue    — instead of gh issue create or gh api
  chetter_issue_comment   — instead of gh issue comment, gh pr comment, or gh api
  chetter_create_pr       — instead of gh pr create or gh api
  chetter_pr_review       — instead of gh pr review or gh api

Read-only gh commands are still available (issue view/list, pr view/checks, etc.).
Use the Chetter MCP tools listed above. These ensure proper audit logging and
canonical Chetter signatures on every artifact.
EOF
  exit 64
}

cmd="${1:-} ${2:-}"
case "$cmd" in
  "api"*) _blocked ;;
  "issue create"|"issue comment"|"pr create"|"pr review"|"pr comment") _blocked ;;
esac

exec /usr/local/bin/gh-real "$@"
