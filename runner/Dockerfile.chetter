# syntax=docker/dockerfile:1.7

# Chetter Runner — Daemon Image
# =========================================================================
# Long-running runner service only. It claims tasks, prepares workspaces, and
# starts per-task agent containers. Harness CLIs and language toolchains live in
# runner/images/* agent images instead of this daemon image.
# =========================================================================

# --------------------------------------------------------------------------
# Stage 1: Build runner binary
# --------------------------------------------------------------------------
FROM golang:1.26-bookworm AS runner-builder

ARG GIT_HASH=unknown

WORKDIR /src
COPY go.mod go.sum* ./
COPY gen/ ./gen/
COPY runner/go.mod runner/go.sum* ./runner/
WORKDIR /src/runner
RUN --mount=type=cache,target=/go/pkg/mod \
    --mount=type=cache,target=/root/.cache/go-build \
    go mod download
WORKDIR /src
COPY runner/ ./runner/
WORKDIR /src/runner
RUN --mount=type=cache,target=/go/pkg/mod \
    --mount=type=cache,target=/root/.cache/go-build \
    CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -ldflags="-s -w -X 'github.com/flatout-works/chetter/runner/cmd/runner._gitHash=${GIT_HASH}'" -o /out/runner ./cmd/runner

# --------------------------------------------------------------------------
# Stage 2: Download Docker CLI
# --------------------------------------------------------------------------
FROM debian:bookworm-slim AS binary-downloader

RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt,sharing=locked \
    apt-get update && apt-get install -y --no-install-recommends ca-certificates curl

ARG DOCKER_VERSION=27.5.1
RUN curl -fsSL "https://download.docker.com/linux/static/stable/x86_64/docker-${DOCKER_VERSION}.tgz" \
    | tar -C /usr/local/bin --strip-components=1 -xzf - docker/docker \
    && chmod +x /usr/local/bin/docker

# --------------------------------------------------------------------------
# Stage 3: Final daemon image
# --------------------------------------------------------------------------
FROM debian:bookworm-slim

ARG GIT_HASH=unknown

ENV GITHUB_SHA=${GIT_HASH}
ENV CHETTER_RUNNER_IMAGE_DIGEST=${GIT_HASH}

RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt,sharing=locked \
    apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
    git \
    openssh-client \
    socat \
    && rm -rf /var/lib/apt/lists/*

ENV TMPDIR=/tmp/chetter-runner

COPY --from=binary-downloader /usr/local/bin/docker /usr/local/bin/docker
COPY --from=runner-builder /out/runner /usr/local/bin/runner
COPY runner/chetter-entrypoint.sh /usr/local/bin/chetter-entrypoint

RUN chmod +x /usr/local/bin/runner /usr/local/bin/docker /usr/local/bin/chetter-entrypoint \
    && mkdir -p /var/lib/chetter-runner/workspaces "$TMPDIR"

ENV RUNNER_LOCAL=false
ENV RUNNER_WORKSPACE_ROOT=/var/lib/chetter-runner/workspaces

WORKDIR /var/lib/chetter-runner/workspaces
ENTRYPOINT ["chetter-entrypoint"]
