# Copy this file to .env and edit the values before starting Chetter.

# Optional: set this to use an external TiDB database instead of the
# bundled TiDB service from deploy/compose.local.yaml.
# DATABASE_DSN=root@tcp(host:4000)/chetter?parseTime=true

# Required bearer token for the MCP endpoint. Set this to a long, random value.
CHETTER_MCP_AUTH_TOKEN=

# Optional dedicated token for runner RPC. Defaults to CHETTER_MCP_AUTH_TOKEN in Compose.
CHETTER_RUNNER_RPC_TOKEN=

# Optional listen addresses inside the server container.
# Compose publishes MCP on localhost:18088 and the web UI/API on localhost:18089.
# HTTP_ADDR=:8080
# WEB_ADDR=:8090

# Optional agent image defaults. If AGENT_IMAGE_PREFIX is set, unqualified
# agent_image values such as chetter-agent:golang are expanded to
# ghcr.io/flatout-works/chetter-agent:golang before runners receive them.
# DEFAULT_AGENT_IMAGE=ghcr.io/flatout-works/chetter-agent-base:latest
# AGENT_IMAGE_PREFIX=ghcr.io/flatout-works

# Optional local chetterctl defaults.
# CHETTER_WEB_URL=http://localhost:18089
# CHETTER_API_URL=http://localhost:18089
# CHETTER_TOKEN=${CHETTER_MCP_AUTH_TOKEN}

# Runner provider keys. Configure at least one provider your OpenCode setup can use.
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
SYNTHETIC_API_KEY=
OPENCODE_API_KEY=

# Optional GitHub token for agents that need to clone private repos or create PRs.
GITHUB_TOKEN=

# Optional persistent memory provider.
MEM9_API_KEY=
MEM9_API_URL=https://api.mem9.ai
MEM9_DEBUG=false
