{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/flatout-works/chetter/main/schemas/model-catalog.schema.json",
  "title": "Chetter model catalog",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "default_provider", "default_model", "providers"],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "default_provider": { "type": "string", "minLength": 1 },
    "default_model": { "type": "string", "minLength": 1 },
    "defaults": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/harnessDefault" }
    },
    "providers": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": { "$ref": "#/$defs/provider" }
    }
  },
  "$defs": {
    "harnessDefault": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider", "model"],
      "properties": {
        "provider": { "type": "string", "minLength": 1 },
        "model": { "type": "string", "minLength": 1 }
      }
    },
    "provider": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "kind": { "type": "string", "enum": ["", "openai_compatible", "native"] },
        "base_url": { "type": "string" },
        "api_key_env": { "type": "string" },
        "models": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/model" }
        },
        "harnesses": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/providerHarness" }
        }
      },
      "required": ["models"]
    },
    "providerHarness": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "base_url": { "type": "string" },
        "api_key_env": { "type": "string" },
        "api": { "type": "string", "enum": ["", "openai-completions", "anthropic-messages"] },
        "auth_header": { "type": "boolean" },
        "disabled": { "type": "boolean" }
      }
    },
    "model": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string" },
        "aliases": {
          "type": "array",
          "items": { "type": "string" }
        },
        "harnesses": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/modelHarness" }
        }
      }
    },
    "modelHarness": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "disabled": { "type": "boolean" },
        "options": { "type": "object", "additionalProperties": true }
      }
    }
  }
}
