{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/flatout-works/chetter/main/schemas/runner.schema.json",
  "title": "Chetter runner config",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "server": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "url": { "type": "string" },
        "auth_token": { "type": "string" }
      }
    },
    "runner": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "workspace_root": { "type": "string" },
        "max_concurrent": { "type": "integer", "minimum": 1 }
      }
    },
    "proxy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "listen_addr": { "type": "string" },
        "allowed_domains": { "type": "array", "items": { "type": "string" } },
        "blocked_domains": { "type": "array", "items": { "type": "string" } }
      }
    },
    "dns": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "listen_addr": { "type": "string" },
        "upstream": { "type": "string" },
        "blocked_domains": { "type": "array", "items": { "type": "string" } }
      }
    },
    "workspace": {
      "type": "object",
      "description": "Reserved for future workspace settings."
    },
    "git": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "ssh_key_path": { "type": "string" },
        "pat": { "type": "string" }
      }
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "runtime": { "type": "string" },
        "harness": { "type": "string", "enum": ["opencode", "claude-code", "pi", "codewhale"] },
        "use_gvisor": { "type": "boolean" },
        "container_memory": { "type": "string" }
      }
    },
    "deploy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "provider": { "type": "string" },
        "registry": { "type": "string" },
        "chetter_url": { "type": "string" }
      }
    }
  }
}
