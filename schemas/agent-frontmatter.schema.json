{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/flatout-works/chetter/main/schemas/agent-frontmatter.schema.json",
  "title": "Chetter agent definition frontmatter",
  "type": "object",
  "additionalProperties": true,
  "required": ["identity"],
  "properties": {
    "description": { "type": "string" },
    "provider": { "type": "string" },
    "model": { "type": "string" },
    "mode": { "type": "string" },
    "identity": {
      "type": "string",
      "description": "Server-managed Git identity reference. Credentials never belong in this file."
    },
    "mcp_endpoints": {
      "type": "array",
      "items": { "type": "string" },
      "description": "MCP endpoint names to mount for tasks using this agent."
    },
    "permission": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    }
  }
}
